{
  "name": "verifiable-shuffle-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:cloudflare": "cp .env.template .env && npm run build",
    "preview": "npm run build:cloudflare && wrangler dev",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "gen": "wrangler types",
    "deploy": "npm run build:cloudflare && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@sveltejs/adapter-cloudflare": "^7.2.6",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^22",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "wrangler": "^4.63.0"
  },
  "dependencies": {
    "@agoralabs-sh/avm-web-provider": "^1.7.0",
    "@algorandfoundation/algokit-utils": "^9.2.0",
    "@blockshake/defly-connect": "^1.2.1",
    "@perawallet/connect": "^1.5.1",
    "@txnlab/use-wallet-svelte": "^4.6.0",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/sign-client": "^2.23.8",
    "lute-connect": "^1.7.0"
  }
}
