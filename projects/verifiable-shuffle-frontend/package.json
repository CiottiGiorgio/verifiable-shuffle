{
	"name": "verifiable-shuffle-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "test -f .env || cp .env.template .env && vite build",
		"preview": "npm run build && wrangler dev",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"gen": "wrangler types",
		"deploy": "npm run build && wrangler deploy",
		"cf-typegen": "wrangler types"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.5.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vite-plugin-node-polyfills": "^0.28.0",
		"wrangler": "^4.97.0"
	},
	"dependencies": {
		"@agoralabs-sh/avm-web-provider": "^1.7.0",
		"@algorandfoundation/algokit-utils": "^9.2.0",
		"@blockshake/defly-connect": "^1.2.1",
		"@perawallet/connect": "^1.5.2",
		"@txnlab/use-wallet-svelte": "^4.6.0",
		"@walletconnect/modal": "^2.7.0",
		"@walletconnect/sign-client": "^2.23.9",
		"lute-connect": "^1.7.0"
	}
}
